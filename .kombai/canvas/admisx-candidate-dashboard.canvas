ms:center; justify-content:center; flex-shrink:0; margin-top:1px;\" data-kid=\"291\">\n                  <svg width=\"10\" height=\"8\" viewBox=\"0 0 10 8\" fill=\"none\" data-kid=\"292\"><path d=\"M1 4l3 3 5-6\" stroke=\"white\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"293\"></path></svg>\n                </div>\n                <span style=\"color:#032D60; font-size:12px; line-height:1.5;\" data-kid=\"294\">Tôi hiểu rằng mọi hành vi gian lận trong hồ sơ sẽ bị hủy kết quả tuyển sinh và có thể bị xử lý theo quy định pháp luật.</span>\n              </label>\n            </div>\n\n            \n            <div style=\"background:rgba(255,154,60,0.08); border:1px solid rgba(255,154,60,0.3); border-radius:6px; padding:10px 12px; margin-bottom:14px; display:flex; align-items:center; gap:8px;\" data-kid=\"295\">\n              <svg width=\"14\" height=\"14\" fill=\"none\" stroke=\"#FF9A3C\" stroke-width=\"2\" viewBox=\"0 0 24 24\" data-kid=\"296\"><circle cx=\"12\" cy=\"12\" r=\"10\" data-kid=\"297\"></circle><line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"12\" data-kid=\"298\"></line><line x1=\"12\" y1=\"16\" x2=\"12.01\" y2=\"16\" data-kid=\"299\"></line></svg>\n              <span style=\"color:#FF9A3C; font-size:11px; font-weight:600;\" data-kid=\"300\">Vui lòng tải đủ tài liệu trước khi nộp</span>\n            </div>\n\n            <button style=\"width:100%; background:#706E6B; color:#fff; border:none; border-radius:4px; height:48px; font-family:'Nunito Sans',sans-serif; font-size:14px; font-weight:700; cursor:not-allowed; display:flex; align-items:center; justify-content:center; gap:8px; opacity:0.65;\" data-kid=\"301\">\n              <svg width=\"18\" height=\"18\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\" data-kid=\"302\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\" data-kid=\"303\"></path><polyline points=\"22 4 12 14.01 9 11.01\" data-kid=\"304\"></polyline></svg>\n              Nộp hồ sơ chính thức\n            </button>\n            <div style=\"text-align:center; color:#706E6B; font-size:11px; margin-top:10px; line-height:1.4;\" data-kid=\"305\">\n              Sau khi nộp, hệ thống sẽ gửi email xác nhận đến<br data-kid=\"306\"><strong style=\"color:#032D60;\" data-kid=\"307\">nguyenvanan@gmail.com</strong>\n            </div>\n          </div>\n        </div>\n\n        \n        <div style=\"background:linear-gradient(135deg, #032D60, #0a4a9e); border-radius:8px; padding:16px;\" data-kid=\"308\">\n          <div style=\"color:#fff; font-size:13px; font-weight:700; margin-bottom:4px;\" data-kid=\"309\">Cần hỗ trợ?</div>\n          <div style=\"color:rgba(255,255,255,0.65); font-size:12px; margin-bottom:12px;\" data-kid=\"310\">Đội ngũ tư vấn sẵn sàng hỗ trợ bạn trong suốt quá trình đăng ký.</div>\n          <button style=\"width:100%; background:#00A1E0; color:#fff; border:none; border-radius:4px; height:36px; font-family:'Nunito Sans',sans-serif; font-size:13px; font-weight:600; cursor:pointer;\" data-kid=\"311\">💬 Chat với tư vấn viên</button>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div style=\"border-top:1px solid #D8DDE6; margin-top:32px; padding:16px 56px; display:flex; align-items:center; justify-content:space-between; background:#fff;\" data-kid=\"312\">\n    <div style=\"display:flex; align-items:center; gap:8px;\" data-kid=\"313\">\n      <img src=\"/api/local/images/src/assets/hero/logo.jpg\" alt=\"AdmiSX\" decoding=\"async\" loading=\"lazy\" style=\"height:24px; width:24px; border-radius:50%; object-fit:cover;\" data-kid=\"314\">\n      <span style=\"color:#706E6B; font-size:12px;\" data-kid=\"315\">© 2024 AdmiSX — Cổng đăng ký tuyển sinh đại học</span>\n    </div>\n    <div style=\"display:flex; gap:20px;\" data-kid=\"316\">\n      <a style=\"color:#706E6B; font-size:12px; text-decoration:none;\" data-kid=\"317\">Điều khoản sử dụng</a>\n      <a style=\"color:#706E6B; font-size:12px; text-decoration:none;\" da