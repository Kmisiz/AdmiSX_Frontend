#706E6B; font-size:11px; text-align:center; margin-top:2px;\" data-kid=\"45\">Hoàn thành</div>\n          <div style=\"position:absolute; top:18px; left:calc(50% + 18px); right:calc(-50% + 18px); height:2px; background:#04844B;\" data-kid=\"46\"></div>\n        </div>\n        <div style=\"flex:1; display:flex; flex-direction:column; align-items:center; position:relative;\" data-kid=\"47\">\n          <div style=\"width:36px; height:36px; border-radius:50%; background:#04844B; display:flex; align-items:center; justify-content:center; z-index:1;\" data-kid=\"48\"><svg width=\"16\" height=\"16\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\" data-kid=\"49\"><path d=\"M20 6 9 17l-5-5\" data-kid=\"50\"></path></svg></div>\n          <div style=\"color:#04844B; font-size:12px; font-weight:600; margin-top:8px; text-align:center;\" data-kid=\"51\">Thông tin học tập</div><div style=\"color:#706E6B; font-size:11px; text-align:center; margin-top:2px;\" data-kid=\"52\">Hoàn thành</div>\n          <div style=\"position:absolute; top:18px; left:calc(50% + 18px); right:calc(-50% + 18px); height:2px; background:#FF9A3C; opacity:0.5;\" data-kid=\"53\"></div>\n        </div>\n        <div style=\"flex:1; display:flex; flex-direction:column; align-items:center; position:relative;\" data-kid=\"54\">\n          <div style=\"width:36px; height:36px; border-radius:50%; background:#FF9A3C; display:flex; align-items:center; justify-content:center; z-index:1; box-shadow:0 0 0 4px rgba(255,154,60,0.2);\" data-kid=\"55\"><span style=\"color:#fff; font-size:13px; font-weight:700;\" data-kid=\"56\">4</span></div>\n          <div style=\"color:#FF9A3C; font-size:12px; font-weight:700; margin-top:8px; text-align:center;\" data-kid=\"57\">Tải minh chứng</div><div style=\"color:#FF9A3C; font-size:11px; text-align:center; margin-top:2px; font-weight:600;\" data-kid=\"58\">Đang thực hiện</div>\n          <div style=\"position:absolute; top:18px; left:calc(50% + 18px); right: