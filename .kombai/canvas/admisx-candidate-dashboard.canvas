ta-kid=\"276\">Lưu nháp</button>\n          <button style=\"display:flex; align-items:center; gap:8px; background:#00A1E0; color:#fff; border:none; border-radius:4px; padding:0 24px; height:40px; font-family:'Nunito Sans',sans-serif; font-size:13px; font-weight:600; cursor:pointer;\" data-kid=\"277\">\n            Tiếp theo: Tải minh chứng\n            <svg width=\"14\" height=\"14\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2\" viewBox=\"0 0 24 24\" data-kid=\"278\"><path d=\"m9 18 6-6-6-6\" data-kid=\"279\"></path></svg>\n          </button>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  \n  <div style=\"border-top:1px solid #D8DDE6; margin-top:32px; padding:16px 56px; display:flex; align-items:center; justify-content:space-between; background:#fff;\" data-kid=\"280\">\n    <div style=\"display:flex; align-items:center; gap:8px;\" data-kid=\"281\">\n      <img src=\"/api/local/images/src/assets/hero/logo.jpg\" alt=\"AdmiSX\" decoding=\"async\" loading=\"lazy\" style=\"height:24px; width:24px; border-radius:50%; object-fit:cover;\" data-kid=\"282\">\n      <span style=\"color:#706E6B; font-size:12px;\" data-kid=\"283\">© 2024 AdmiSX — Cổng đăng ký tuyển sinh đại học</span>\n    </div>\n    <div style=\"display:flex; gap:20px;\" data-kid=\"284\">\n      <a style=\"color:#706E6B; font-size:12px; text-decoration:none;\" data-kid=\"285\">Điều khoản sử dụng</a>\n      <a style=\"color:#706E6B; font-size:12px; text-decoration:none;\" data-kid=\"286\">Chính sách bảo mật</a>\n      <a style=\"color:#00A1E0; font-size:12px; font-weight:600; text-decoration:none;\" data-kid=\"287\">1900-xxxx</a>\n    </div>\n  </div>\n</div>\n",
