</div>\n                <div style=\"flex:1;\" data-kid=\"206\">\n                  <div style=\"color:#032D60; font-size:13px; font-weight:600;\" data-kid=\"207\">KV2</div>\n                  <div style=\"color:#706E6B; font-size:11px;\" data-kid=\"208\">Nông thôn (không thuộc KV1 và KV3)</div>\n                </div>\n                <span style=\"background:#F4F6F9; color:#706E6B; font-size:11px; font-weight:700; padding:2px 8px; border-radius:3px;\" data-kid=\"209\">+0.50</span>\n              </label>\n              <label style=\"display:flex; align-items:center; gap:10px; padding:10px 14px; border:1px solid #D8DDE6; border-radius:4px; cursor:pointer;\" data-kid=\"210\">\n                <div style=\"width:16px; height:16px; border-radius:50%; border:2px solid #D8DDE6;\" data-kid=\"211\"></div>\n                <div style=\"flex:1;\" data-kid=\"212\">\n                  <div style=\"color:#032D60; font-size:13px; font-weight:600;\" data-kid=\"213\">KV2-NT</div>\n                  <div style=\"color:#706E6B; font-size:11px;\" data-kid=\"214\">Ngoại thành các thành phố trực thuộc TW</div>\n                </div>\n                <span style=\"background:#F4F6F9; color:#706E6B; font-size:11px; font-weight:700; padding:2px 8px; border-radius:3px;\" data-kid=\"215\">+0.25</span>\n              </label>\n              <label style=\"display:flex; align-items:center; gap:10px; padding:10px 14px; border:1px solid #D8DDE6; border-radius:4px; cursor:pointer;\" data-kid=\"216\">\n                <div style=\"width:16px; height:16px; border-radius:50%; border:2px solid #D8DDE6;\" data-kid=\"217\"></div>\n                <div style=\"flex:1;\" data-kid=\"218\">\n                  <div style=\"color:#032D60; font-size:13px; font-weight:600;\" data-kid=\"219\">KV3</div>\n                  <div style=\"color:#706E6B; font-size:11px;\" data-kid=\"220\">Thành phố trực thuộc TW và các thành phố khác</div>\n                </div>\n                <span style=\"background:#F4F6F9;